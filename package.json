{
  "name": "arc-mcp-xsuaa-auth",
  "version": "0.1.0",
  "description": "XSUAA / OAuth authentication + BTP principal propagation for Model Context Protocol (MCP) servers built on Express and @modelcontextprotocol/sdk.",
  "license": "MIT",
  "author": "Marian Zeis",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sap",
    "btp",
    "xsuaa",
    "oauth",
    "oauth2",
    "authentication",
    "principal-propagation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arc-mcp/xsuaa-auth.git"
  },
  "homepage": "https://github.com/arc-mcp/xsuaa-auth#readme",
  "bugs": {
    "url": "https://github.com/arc-mcp/xsuaa-auth/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./btp": {
      "types": "./dist/btp.d.ts",
      "default": "./dist/btp.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check:exports": "publint && attw --pack . --profile esm-only",
    "prepare": "husky || true",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.{ts,js,json}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^4.7.0",
    "@sap/xssec": "^4"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.18.2 <2",
    "express": "^5.0.1",
    "jose": ">=5 <7"
  },
  "peerDependenciesMeta": {
    "jose": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@biomejs/biome": "^1.9.4",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "express": "^5.2.1",
    "husky": "^9.1.7",
    "jose": "^6.2.2",
    "lint-staged": "^17.0.7",
    "publint": "^0.3.0",
    "supertest": "^7.2.2",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
